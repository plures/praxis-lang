{
  "name": "@plures/px-napi",
  "version": "0.0.0",
  "description": "NAPI-RS bindings for the .px Praxis Intent Language (parse/evaluate/check_constraints over the canonical Rust engine).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/praxis-lang"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "px-napi",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test/smoke.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
